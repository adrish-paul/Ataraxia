<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Ataraxia" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Make Dialog Background Transparent to prevent rectangular background overlay -->
        <item name="android:dialogTheme">@style/CustomDialogTheme</item>
        <item name="android:alertDialogTheme">@style/CustomDialogTheme</item>
    </style>

    <style name="CustomDialogTheme" parent="android:Theme.DeviceDefault.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>